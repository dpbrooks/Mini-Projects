% Get results of queries
adult(P1, Response) :-
    Val = adult(P1),
    Val -> (write("Yes, "), write(P1), write(" is an adult."), Response = "");
           (write("No, "), write(P1), write(" is not an adult."), Response = "").
child(P1, Response) :-
    Val = child(P1),
    Val -> Response = "Yes, they are an child";
           Response = "No, they are not an child".
baby(P1, Response) :-
    Val = baby(P1),
    Val -> Response = "Yes, they are an baby";
           Response = "No, they are not an baby".
father(P1, P2, Response) :-
    Val = father(P1, P2),
    Val -> Response = "Yes, he is their father.";
           Response = "No, he is not their father.".
mother(P1, P2, Response) :-
    Val - mother(P1, P2),
    Val -> (write("Yes, "), write(P1), write(" is "), write(P2), write('\'s mother'), Response = ""); % Find out how to use a single quote to make the second person possesive
           (write("False"), Response = "").

married(P1, P2, Response) :-
    Val = married(P1, P2),
    Val -> Response = "Yes, they are married.";
           Response = "No, they are not married.".

% Determine the type of query being asked
determinequery([is, X, an, Z, ?], Response) :-
    (Z = adult) -> (adult(X, Res), Response = Res), !;
    Response = "Relationship not in data set.", !.

determinequery([is, X, a, Z, ?], Response) :-
    (Z = child) -> (child(X, Res), Response = Res), !;
    (Z = baby) -> (baby(X, Res), Response = Res), !;
    Response = "Relationship not in data set.", !.

determinequery([is, X, the, Z, of, Y, ?], Response) :-
    (Z = father) -> (father(X, Y, Res), Response = Res), !;
    (Z = mother) -> (mother(X, Y, Res), Response = Res), !;
    Response = "Relationship not in data set.", !.

determinequery([are, X, and, Y, Z, ?], Response) :-
    (Z = married) -> (married(X, Y, Res), Response = Res), !.

determinequery(Ans, Response) :-
    Ans = [quit],
    Response = "Leaving Conversation.",
    !.

determinequery([_], Response) :-
    Response = "Invalid input".

query :-
